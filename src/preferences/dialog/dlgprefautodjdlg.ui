       <item row="0" column="1">
        <widget class="QCheckBox" name="SmartQueueCheckBox">
         <property name="toolTip">
          <string>When enabled, Auto DJ ranks candidate tracks by harmonic key compatibility and BPM proximity (including half/double tempo) instead of pure random selection.</string>
